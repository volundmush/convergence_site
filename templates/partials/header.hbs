<header class="fixed-header">
	<button class="hamburger" id="hamburger" aria-label="Toggle menu">☰</button>
	<nav class="navbar">
		<div class="nav-brand">
			<a href="/">Convergence MUSH</a>
		</div>
		<div class="nav-links">
			{{#each (nav "main")}}
				<div class="nav-item-wrapper {{this.cssClass}}">
					{{#if this.children}}
						<button class="nav-dropdown-toggle">{{this.label}} <span class="dropdown-arrow">▼</span></button>
						<ul class="nav-submenu">
							{{#each this.children}}
								<li class="nav-subitem {{this.cssClass}}">
									<a href="{{this.url}}" class="nav-link">{{this.label}}</a>
								</li>
							{{/each}}
						</ul>
					{{else}}
						<a href="{{this.url}}" class="nav-link">{{this.label}}</a>
					{{/if}}
				</div>
			{{/each}}
			<div class="nav-user">
				{{#if user}}
					<a href="/admin/" class="admin-link">Admin UI</a>
					<a href="/signout/" id="signout-btn" class="signout-link">Sign Out as {{ user.characterName }}</a>
				{{else}}
					<a href="/signin/" class="signin-link">Sign In</a>
				{{/if}}
			</div>
		</div>
	</nav>
	</nav>
</header>

<aside class="sidebar" id="sidebar">
	{{#each (nav "main")}}
		<div class="sidebar-item">
			<a href="{{this.url}}" class="sidebar-link">{{this.label}}</a>
			{{#if this.children}}
				<ul class="sidebar-submenu">
					{{#each this.children}}
						<li><a href="{{this.url}}">{{this.label}}</a></li>
					{{/each}}
				</ul>
			{{/if}}
		</div>
	{{/each}}
	{{#if user}}
		<div class="sidebar-user">{{ user.characterName }}</div>
		<div class="sidebar-item">
			<a href="/admin/" class="sidebar-link">Admin</a>
		</div>
		<div class="sidebar-item">
			<a href="/signout/" id="sidebar-signout" class="sidebar-link">Sign Out</a>
		</div>
	{{else}}
		<div class="sidebar-item">
			<a href="/signin/" class="sidebar-link">Sign In</a>
		</div>
	{{/if}}
</aside>

<script>
	const hamburger = document.getElementById('hamburger')
	const sidebar = document.getElementById('sidebar')
	
	// Toggle sidebar on hamburger click
	hamburger.addEventListener('click', () => {
		sidebar.classList.toggle('open')
	})
	
	// Close sidebar when clicking outside
	document.addEventListener('click', (e) => {
		if (!e.target.closest('.sidebar') && !e.target.closest('.hamburger')) {
			sidebar.classList.remove('open')
		}
	})
	
	// Close sidebar when a link is clicked
	sidebar.querySelectorAll('.sidebar-link, .sidebar-submenu a').forEach(link => {
		link.addEventListener('click', () => {
			sidebar.classList.remove('open')
		})
	})
	
	// Sidebar signout
	document.getElementById('sidebar-signout')?.addEventListener('click', async (e) => {
		e.preventDefault()
		try {
			const response = await fetch('/signout/', {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' }
			})
			if (response.ok) {
				window.location.href = '/'
			}
		} catch (error) {
			console.error('Sign out failed:', error)
		}
	})

	// Dropdown toggle functionality for desktop nav
	document.querySelectorAll('.nav-dropdown-toggle').forEach(toggle => {
		toggle.addEventListener('click', (e) => {
			e.preventDefault()
			const wrapper = toggle.closest('.nav-item-wrapper')
			wrapper.classList.toggle('active')
		})
	})

	// Close dropdowns when clicking outside
	document.addEventListener('click', (e) => {
		if (!e.target.closest('.nav-item-wrapper')) {
			document.querySelectorAll('.nav-item-wrapper.active').forEach(item => {
				item.classList.remove('active')
			})
		}
	})

	// Close dropdowns when a submenu link is clicked
	document.querySelectorAll('.nav-submenu a').forEach(link => {
		link.addEventListener('click', () => {
			document.querySelectorAll('.nav-item-wrapper.active').forEach(item => {
				item.classList.remove('active')
			})
		})
	})

	// Desktop nav signout
	document.getElementById('signout-btn')?.addEventListener('click', async (e) => {
		e.preventDefault()
		try {
			const response = await fetch('/signout/', {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' }
			})

			if (response.ok) {
				window.location.href = '/'
			}
		} catch (error) {
			console.error('Sign out failed:', error)
		}
	})
</script>
