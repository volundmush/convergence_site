<header class="fixed-header">
	<button class="hamburger" id="hamburger" aria-label="Toggle menu">☰</button>
	<nav class="navbar">
		<div class="nav-brand">
			<a href="/">Convergence MUSH</a>
		</div>
		<div class="nav-links">
			{{#each (nav "main")}}
				{{> nav-item}}
			{{/each}}
			{{#if user}}
				<a href="/admin/" class="nav-link admin-link">Admin</a>
				<a href="/signout/" id="signout-btn" class="nav-link signout-link">Sign Out</a>
			{{else}}
				<a href="/signin/" class="nav-link signin-link">Sign In</a>
			{{/if}}
		</div>
	</nav>
</header>

<aside class="sidebar" id="sidebar">
	{{#each (nav "main")}}
		{{> sidebar-item}}
	{{/each}}
	{{#if user}}
		<div class="sidebar-user">{{ user.characterName }}</div>
		<div class="sidebar-item">
			<a href="/admin/" class="sidebar-link">Admin</a>
		</div>
		<div class="sidebar-item">
			<a href="/signout/" id="sidebar-signout" class="sidebar-link">Sign Out</a>
		</div>
	{{else}}
		<div class="sidebar-item">
			<a href="/signin/" class="sidebar-link">Sign In</a>
		</div>
	{{/if}}
</aside>

<script>
	const hamburger = document.getElementById('hamburger')
	const sidebar = document.getElementById('sidebar')
	
	// ===== HAMBURGER & SIDEBAR =====
	hamburger.addEventListener('click', () => {
		sidebar.classList.toggle('open')
	})
	
	// Close sidebar when clicking outside
	document.addEventListener('click', (e) => {
		if (!e.target.closest('.sidebar') && !e.target.closest('.hamburger')) {
			sidebar.classList.remove('open')
		}
	})
	
	// Close sidebar when a link is clicked
	sidebar.querySelectorAll('.sidebar-link').forEach(link => {
		link.addEventListener('click', () => {
			sidebar.classList.remove('open')
		})
	})
	
	// ===== SIDEBAR NESTED TOGGLE =====
	sidebar.querySelectorAll('.sidebar-item-toggle').forEach(toggle => {
		toggle.addEventListener('click', (e) => {
			e.preventDefault()
			const sidebarItem = toggle.closest('.sidebar-item')
			sidebarItem.classList.toggle('open')
		})
	})

	// Sidebar signout
	document.getElementById('sidebar-signout')?.addEventListener('click', async (e) => {
		e.preventDefault()
		try {
			const response = await fetch('/signout/', {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' }
			})
			if (response.ok) {
				window.location.href = '/'
			}
		} catch (error) {
			console.error('Sign out failed:', error)
		}
	})

	// ===== NAVBAR NESTED DROPDOWNS =====
	// Handle navbar dropdown toggle with nested support
	document.querySelectorAll('.nav-dropdown-toggle').forEach(toggle => {
		toggle.addEventListener('click', (e) => {
			e.stopPropagation()
			const wrapper = toggle.closest('.nav-item-wrapper')
			const isActive = wrapper.classList.contains('active')
			
			// Close all other dropdowns at the same level
			const parent = wrapper.parentElement
			if (parent) {
				parent.querySelectorAll(':scope > .nav-item-wrapper.active').forEach(item => {
					if (item !== wrapper) item.classList.remove('active')
				})
			}
			
			// Toggle current dropdown
			wrapper.classList.toggle('active')
		})
	})

	// Close dropdowns when clicking outside navbar
	document.addEventListener('click', (e) => {
		if (!e.target.closest('.navbar')) {
			document.querySelectorAll('.nav-item-wrapper.active').forEach(item => {
				item.classList.remove('active')
			})
		}
	})

	// Prevent closing dropdown when clicking inside it
	document.querySelectorAll('.nav-submenu').forEach(submenu => {
		submenu.addEventListener('click', (e) => {
			e.stopPropagation()
		})
	})

	// Close dropdown when a final link (no children) is clicked
	document.querySelectorAll('.nav-link:not(.nav-dropdown-toggle)').forEach(link => {
		link.addEventListener('click', () => {
			document.querySelectorAll('.nav-item-wrapper.active').forEach(item => {
				item.classList.remove('active')
			})
		})
	})

	// Desktop nav signout
	document.getElementById('signout-btn')?.addEventListener('click', async (e) => {
		e.preventDefault()
		try {
			const response = await fetch('/signout/', {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' }
			})

			if (response.ok) {
				window.location.href = '/'
			}
		} catch (error) {
			console.error('Sign out failed:', error)
		}
	})
</script>
