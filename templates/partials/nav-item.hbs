{{!-- Recursive partial for rendering navigation items with unlimited nesting --}}
{{#if this.children.length}}
	<div class="nav-item-wrapper {{this.cssClass}}" data-nav-id="{{this.id}}">
		<button class="nav-dropdown-toggle" aria-label="Toggle {{this.label}} submenu">
			{{this.label}} 
			<span class="dropdown-arrow">▼</span>
		</button>
		<ul class="nav-submenu">
			{{#each this.children}}
				<li class="nav-subitem">
					{{> nav-item}}
				</li>
			{{/each}}
		</ul>
	</div>
{{else}}
	<div class="nav-item-wrapper {{this.cssClass}}" data-nav-id="{{this.id}}">
		<a href="{{this.url}}" target="{{this.target}}" class="nav-link">{{this.label}}</a>
	</div>
{{/if}}
