<!-- {"title": "Factions", "slug": "factions"} -->

<h2>Factions</h2>

<div class="factions-container" id="factions-container">
	<p>Loading factions...</p>
</div>

<script>
	async function loadFactions() {
		try {
			const res = await fetch('/gapi/factions/list/')
			const factions = await res.json()
			const container = document.getElementById('factions-container')
			
			if (!factions || factions.length === 0) {
				container.innerHTML = '<p>No factions found.</p>'
				return
			}
			
			container.innerHTML = factions.map(faction => `
				<div class="faction-card">
					<div class="faction-header">
						<h3>${faction.name}</h3>
						<button class="expand-toggle collapsed" data-faction-id="${faction.id}">▼</button>
					</div>
					
					<div class="faction-content collapsed" id="faction-${faction.id}">
						<div class="faction-description">
							<p>${faction.description}</p>
						</div>
						
						<div class="faction-members">
							<h4>Members (${faction.members?.length || 0})</h4>
							<div class="members-list">
								${(faction.members || []).map(member => `
									<div class="member-item">
										<div class="member-name">${member.name}</div>
										<div class="member-info">
											<span class="member-rank">${member.rank}</span>
											${member.title ? `<span class="member-title">${member.title}</span>` : ''}
										</div>
									</div>
								`).join('')}
							</div>
						</div>
					</div>
				</div>
			`).join('')
			
			// Event delegation for toggle buttons
			container.addEventListener('click', (e) => {
				const toggle = e.target.closest('.expand-toggle')
				if (toggle) {
					e.stopPropagation()
					const factionId = toggle.dataset.factionId
					const content = document.getElementById(`faction-${factionId}`)
					toggle.classList.toggle('collapsed')
					content.classList.toggle('collapsed')
				}
			})
			
			// Event delegation for header click
			container.addEventListener('click', (e) => {
				const header = e.target.closest('.faction-header')
				if (header) {
					const toggle = header.querySelector('.expand-toggle')
					toggle.click()
				}
			})
		} catch (error) {
			console.error('Failed to load factions:', error)
			document.getElementById('factions-container').innerHTML = '<p>Failed to load factions.</p>'
		}
	}
	
	document.addEventListener('DOMContentLoaded', loadFactions)
</script>
